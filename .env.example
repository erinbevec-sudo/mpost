POSTGRES_DB=mpost
POSTGRES_USER=mpost
POSTGRES_PASSWORD=mpost
DATABASE_URL=postgresql+psycopg://mpost:mpost@postgres:5432/mpost
LOCAL_DATABASE_URL=postgresql://mpost:mpost@localhost:55432/mpost

API_HOST=0.0.0.0
API_PORT=8000

# POC-only auth header. Replace with OIDC/JWT validation before real use.
MPOST_DEV_USER_EMAIL=user@example.com
MPOST_DEV_USER_ROLE=user

# LLM settings for executive summaries
# Options: "huggingface" (cloud, recommended), "ollama" (local), or "fallback" (extractive only)
LLM_PROVIDER=huggingface

# Hugging Face Inference API (recommended for deployments)
# Free tier available, no local setup needed
# Get token at: https://huggingface.co/settings/tokens
# Recommended models: meta-llama/Llama-3.2-3B-Instruct, Qwen/Qwen2.5-3B-Instruct
HF_MODEL=meta-llama/Llama-3.2-3B-Instruct
HF_API_TOKEN=

# Ollama (local alternative)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

VITE_API_URL=http://localhost:8000

# Embedding Model (for both ingestion and API search)
# Use sentence-transformers/all-MiniLM-L6-v2 for HF embeddings (384 dim)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
